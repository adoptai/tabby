# Copy this file to .env.local for local operator use:
#   cp .env.example .env.local
# Then set real secrets/values before running Slack HITL tests.

# Core local endpoints
API_URL=http://localhost:18080
API_BASE_URL=http://localhost:18080
NATS_URL=nats://localhost:4222

# Local admin fallback auth for soft HITL bridge
ADMIN_EMAIL=admin@browser-hitl.local
ADMIN_PASSWORD=e2e-admin-password

# Slack routing (required for soft bridge)
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_CHANNEL=tabby-experiments

# Leave service auth blank for local admin-login fallback.
# If you explicitly use service auth, set both values.
SERVICE_AUTH_CLIENT_ID=
SERVICE_AUTH_CLIENT_SECRET=

# Local operator posture for manual testing
SLACK_SOFT_ALLOW_UNRESTRICTED_OPERATORS=true
