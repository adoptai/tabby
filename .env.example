# =============================================================================
# Browser HITL — Local Development Environment
# =============================================================================
# Copy this file to .env.local:
#   cp .env.example .env.local
#
# These defaults match docker-compose.yml for local infra (postgres, redis,
# nats, minio). Source the file before running any service locally:
#   set -a && source .env.local && set +a
#   pnpm --filter @browser-hitl/api start:dev
# =============================================================================

# ---------------------------------------------------------------------------
# Core infrastructure (must match docker-compose.yml)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://browser_hitl:localdev@localhost:5432/browser_hitl
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# MinIO (S3-compatible blob storage)
MINIO_ENDPOINT=localhost
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# Security — generate real values for anything beyond local dev
# ---------------------------------------------------------------------------
# JWT signing key (min 32 chars). Generate with: openssl rand -hex 32
JWT_SIGNING_KEY=REPLACE_ME_min_32_chars

# Tenant encryption key (AES-256-GCM, 64-char hex / 32 bytes).
# Generate with: openssl rand -hex 32
TENANT_ENCRYPTION_KEY=REPLACE_ME_64_char_hex

# ---------------------------------------------------------------------------
# API endpoints
# ---------------------------------------------------------------------------
API_URL=http://localhost:18080
API_BASE_URL=http://localhost:18080

# ---------------------------------------------------------------------------
# Admin bootstrap auth
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@browser-hitl.local
ADMIN_PASSWORD=e2e-admin-password

# ---------------------------------------------------------------------------
# Slack integration (required for soft bridge / Slack bot)
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_CHANNEL=tabby-experiments
SLACK_SOFT_ALLOW_UNRESTRICTED_OPERATORS=true

# ---------------------------------------------------------------------------
# Service-to-service auth (leave blank for local admin-login fallback)
# ---------------------------------------------------------------------------
SERVICE_AUTH_CLIENT_ID=
SERVICE_AUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# IdP secrets (required for OAuth browser flow)
# Leave empty if not using browser OAuth
# ---------------------------------------------------------------------------
IDP_CLIENT_ID=
IDP_CLIENT_SECRET=
