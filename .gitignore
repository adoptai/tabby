# ============================================================
# Browser HITL MVP - .gitignore
# ============================================================

# --- Node.js / pnpm ---
node_modules/
.pnpm-store/
.pnpm-debug.log

# --- Build outputs ---
dist/
build/
*.tsbuildinfo

# --- NX ---
.nx/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Environment / Secrets ---
.env
.env.*
!.env.example

# --- Logs ---
*.log
npm-debug.log*
pnpm-debug.log*

# --- Test ---
coverage/
.jest/
junit.xml

# --- E2E smoke test results (ephemeral, per-run evidence) ---
e2e_smoke_test/results/run_*/
e2e_smoke_test/results/manual_slack_hitl_*/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- Docker ---
*.tar
*.gz

# --- Kubernetes / Helm ---
charts/**/charts/
charts/**/*.tgz

# --- MinIO data (if running locally) ---
minio-data/

# --- Temporary files ---
/tmp/
*.tmp
*.bak
*.pid
.tabby-noui-client.json

# --- SBOM artifacts (generated, not committed) ---
*.sbom.json
*.sbom.json.sig

# --- Implementation tracker artifacts (generated evidence) ---
implementation_tracker/**/evidence/
implementation_tracker/**/secret_apply.json
implementation_tracker/**/sbom/

# --- OS ---
.DS_Store
.Spotlight-V100
.Trashes

